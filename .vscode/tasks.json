{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Django Server (.venv310)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv310\\Scripts\\python.exe",
      "args": ["manage.py", "runserver"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
